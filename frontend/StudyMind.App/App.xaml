<Application
    x:Class="StudyMind.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="StudyMindPageBackgroundBrush" Color="#F6F8FA" />
                    <SolidColorBrush x:Key="StudyMindPanelBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="StudyMindHeroBrush" Color="#EAF6F3" />
                    <SolidColorBrush x:Key="StudyMindSoftSurfaceBrush" Color="#F2F5F7" />
                    <SolidColorBrush x:Key="StudyMindPanelStrokeBrush" Color="#D8E0E7" />
                    <SolidColorBrush x:Key="StudyMindAccentBrush" Color="#0F766E" />
                    <SolidColorBrush x:Key="StudyMindAccentSoftBrush" Color="#99F6E4" />
                    <SolidColorBrush x:Key="StudyMindSuccessBrush" Color="#15803D" />
                    <SolidColorBrush x:Key="StudyMindSuccessSoftBrush" Color="#DCFCE7" />
                    <SolidColorBrush x:Key="StudyMindInfoBrush" Color="#1E40AF" />
                    <SolidColorBrush x:Key="StudyMindInfoSoftBrush" Color="#DBEAFE" />
                    <SolidColorBrush x:Key="StudyMindWarningBrush" Color="#92400E" />
                    <SolidColorBrush x:Key="StudyMindWarningSoftBrush" Color="#FEF3C7" />
                    <SolidColorBrush x:Key="StudyMindDangerBrush" Color="#B91C1C" />
                    <SolidColorBrush x:Key="StudyMindDangerSoftBrush" Color="#FEE2E2" />
                    <SolidColorBrush x:Key="StudyMindTextMutedBrush" Color="#52616B" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="StudyMindPageBackgroundBrush" Color="#101418" />
                    <SolidColorBrush x:Key="StudyMindPanelBrush" Color="#182026" />
                    <SolidColorBrush x:Key="StudyMindHeroBrush" Color="#102A2B" />
                    <SolidColorBrush x:Key="StudyMindSoftSurfaceBrush" Color="#1F2933" />
                    <SolidColorBrush x:Key="StudyMindPanelStrokeBrush" Color="#34414D" />
                    <SolidColorBrush x:Key="StudyMindAccentBrush" Color="#5EEAD4" />
                    <SolidColorBrush x:Key="StudyMindAccentSoftBrush" Color="#2D6F68" />
                    <SolidColorBrush x:Key="StudyMindSuccessBrush" Color="#86EFAC" />
                    <SolidColorBrush x:Key="StudyMindSuccessSoftBrush" Color="#163927" />
                    <SolidColorBrush x:Key="StudyMindInfoBrush" Color="#93C5FD" />
                    <SolidColorBrush x:Key="StudyMindInfoSoftBrush" Color="#1E3A5F" />
                    <SolidColorBrush x:Key="StudyMindWarningBrush" Color="#FCD34D" />
                    <SolidColorBrush x:Key="StudyMindWarningSoftBrush" Color="#4A3516" />
                    <SolidColorBrush x:Key="StudyMindDangerBrush" Color="#FCA5A5" />
                    <SolidColorBrush x:Key="StudyMindDangerSoftBrush" Color="#4A2020" />
                    <SolidColorBrush x:Key="StudyMindTextMutedBrush" Color="#B8C2CC" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
