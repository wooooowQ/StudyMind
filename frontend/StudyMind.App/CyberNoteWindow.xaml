<Window
    x:Class="StudyMind.App.CyberNoteWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid
        x:Name="Root"
        Background="#FFF4BF"
        RequestedTheme="Light"
        KeyDown="Root_KeyDown">
        <Grid.Resources>
            <SolidColorBrush x:Key="NoteInkBrush" Color="#46320F" />
            <SolidColorBrush x:Key="NoteMutedBrush" Color="#7A6535" />
            <SolidColorBrush x:Key="NotePaperBrush" Color="#FFF2B8" />
            <SolidColorBrush x:Key="NotePaperSoftBrush" Color="#FFF8D8" />
            <SolidColorBrush x:Key="NoteHeaderBrush" Color="#F4D364" />
            <SolidColorBrush x:Key="NoteEdgeBrush" Color="#C98F1E" />
            <SolidColorBrush x:Key="NoteLineBrush" Color="#D7B75F" />
            <SolidColorBrush x:Key="NoteAccentBrush" Color="#C98214" />
            <SolidColorBrush x:Key="NoteWarningBrush" Color="#C94525" />

            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource NoteInkBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="NoteButtonStyle" TargetType="Button">
                <Setter Property="MinWidth" Value="30" />
                <Setter Property="MinHeight" Value="30" />
                <Setter Property="Padding" Value="6" />
                <Setter Property="CornerRadius" Value="7" />
                <Setter Property="Background" Value="#1FFFFFFF" />
                <Setter Property="BorderBrush" Value="#A98D6722" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Foreground" Value="{StaticResource NoteInkBrush}" />
            </Style>

            <Style x:Key="NotePrimaryButtonStyle" BasedOn="{StaticResource NoteButtonStyle}" TargetType="Button">
                <Setter Property="MinWidth" Value="126" />
                <Setter Property="MinHeight" Value="34" />
                <Setter Property="Background" Value="#D89A25" />
                <Setter Property="BorderBrush" Value="#AC741D" />
                <Setter Property="Foreground" Value="#FFF8DF" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="PaperPanelStyle" TargetType="Border">
                <Setter Property="Padding" Value="11" />
                <Setter Property="CornerRadius" Value="9" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="#88C99A32" />
                <Setter Property="Background" Value="#54FFF8D9" />
            </Style>

            <Style x:Key="PaperRowStyle" TargetType="Border">
                <Setter Property="Padding" Value="0,8,0,9" />
                <Setter Property="BorderThickness" Value="0,0,0,1" />
                <Setter Property="BorderBrush" Value="#66CFAE55" />
                <Setter Property="Background" Value="Transparent" />
            </Style>

            <Style x:Key="PaperLabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource NoteAccentBrush}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="PaperMetaStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource NoteMutedBrush}" />
                <Setter Property="FontSize" Value="11" />
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="Background" Value="#AFFFF8D8" />
                <Setter Property="BorderBrush" Value="#A6B48228" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="9" />
                <Setter Property="Foreground" Value="{StaticResource NoteInkBrush}" />
                <Setter Property="PlaceholderForeground" Value="#887A6535" />
            </Style>
        </Grid.Resources>

        <Border
            Margin="0"
            BorderBrush="{StaticResource NoteEdgeBrush}"
            BorderThickness="1.25"
            CornerRadius="15">
            <Border.Background>
                <ImageBrush ImageSource="ms-appx:///Assets/sticky-note-paper.png" Stretch="UniformToFill" />
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="46" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Canvas Grid.RowSpan="4" IsHitTestVisible="False">
                    <Rectangle Width="900" Height="1000" Opacity="0.38">
                        <Rectangle.Fill>
                            <RadialGradientBrush Center="0.16,0.04" GradientOrigin="0.12,0.02" RadiusX="0.74" RadiusY="0.56">
                                <GradientStop Color="#FFFFFBDF" Offset="0" />
                                <GradientStop Color="#00FFFBDF" Offset="1" />
                            </RadialGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Rectangle Width="900" Height="1000" Opacity="0.22">
                        <Rectangle.Fill>
                            <RadialGradientBrush Center="0.92,0.94" GradientOrigin="0.9,0.94" RadiusX="0.46" RadiusY="0.36">
                                <GradientStop Color="#FFE9BD54" Offset="0" />
                                <GradientStop Color="#00E9BD54" Offset="1" />
                            </RadialGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Path Data="M28,132 C132,109 207,151 316,124 S498,104 660,134" Stroke="#8B6A21" StrokeThickness="0.65" Opacity="0.045" />
                    <Path Data="M-30,36 L720,760" Stroke="#FFFFFF" StrokeThickness="0.8" Opacity="0.11" />
                    <Path Data="M95,-10 L770,665" Stroke="#A0741F" StrokeThickness="0.55" Opacity="0.035" />
                    <Path Data="M24,372 C134,338 210,390 322,356 S520,330 690,368" Stroke="#FFFFFF" StrokeThickness="3.2" Opacity="0.065" />
                    <Path Data="M0,520 C108,496 192,535 302,512 S508,484 694,527" Stroke="#A0741F" StrokeThickness="0.6" Opacity="0.04" />
                </Canvas>

                <Canvas
                    Grid.RowSpan="4"
                    Width="54"
                    Height="54"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,1,1"
                    IsHitTestVisible="False">
                    <Path
                        Data="M54,54 L12,54 C32,48 49,30 54,12 Z"
                        Fill="#9D8B5A12"
                        Opacity="0.18" />
                    <Path Data="M54,54 L18,54 C35,48 50,34 54,18 Z">
                        <Path.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FFFFEAAF" Offset="0" />
                                <GradientStop Color="#FFE9BE56" Offset="0.72" />
                                <GradientStop Color="#FFD0972C" Offset="1" />
                            </LinearGradientBrush>
                        </Path.Fill>
                    </Path>
                    <Path
                        Data="M18,53 C36,48 50,34 54,18"
                        Stroke="#B77E20"
                        StrokeThickness="0.8"
                        Opacity="0.44" />
                    <Path
                        Data="M35,48 C44,40 50,31 53,22"
                        Stroke="#FFF4CF84"
                        StrokeThickness="1.4"
                        Opacity="0.5" />
                </Canvas>

                <Border
                    Grid.Row="0"
                    Background="#DDF4D364"
                    BorderBrush="#C4972F"
                    BorderThickness="0,0,0,1"
                    CornerRadius="14,14,0,0">
                    <Grid ColumnSpacing="8" Padding="15,0,10,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid
                            x:Name="DragHandle"
                            Background="Transparent"
                            PointerPressed="DragHandle_PointerPressed"
                            ToolTipService.ToolTip="拖动便签"
                            AutomationProperties.Name="拖动便签">
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Grid Width="24" Height="24">
                                    <Border
                                        Background="#F6C545"
                                        BorderBrush="#B98720"
                                        BorderThickness="1"
                                        CornerRadius="4" />
                                    <Path
                                        Data="M14,24 L24,14 L24,24 Z"
                                        Fill="#FFE595"
                                        Stroke="#B98720"
                                        StrokeThickness="0.8" />
                                </Grid>
                                <StackPanel Spacing="0">
                                    <TextBlock Text="StudyMind 便签" FontSize="15" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding NavigationHintText}" Style="{StaticResource PaperMetaStyle}" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                            <Button
                                Command="{Binding Study.RefreshCommand}"
                                Style="{StaticResource NoteButtonStyle}"
                                ToolTipService.ToolTip="刷新数据"
                                AutomationProperties.Name="刷新便签数据">
                                <FontIcon Glyph="&#xE72C;" FontSize="12" />
                            </Button>
                            <Button
                                Click="OpenMain_Click"
                                Style="{StaticResource NoteButtonStyle}"
                                ToolTipService.ToolTip="打开主窗口"
                                AutomationProperties.Name="打开 StudyMind 主窗口">
                                <FontIcon Glyph="&#xE8A7;" FontSize="12" />
                            </Button>
                            <Button
                                Click="Hide_Click"
                                Style="{StaticResource NoteButtonStyle}"
                                ToolTipService.ToolTip="隐藏便签"
                                AutomationProperties.Name="隐藏便签">
                                <FontIcon Glyph="&#xE711;" FontSize="12" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="24,18,22,8" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="5">
                        <TextBlock
                            Text="{Binding PageTitle}"
                            FontFamily="KaiTi, Microsoft YaHei UI"
                            FontSize="29"
                            FontWeight="SemiBold"
                            LineHeight="34" />
                        <Border Width="128" Height="5" HorizontalAlignment="Left" CornerRadius="3" Background="#EDC34F" Opacity="0.72" />
                        <TextBlock Text="{Binding PageSubtitle}" Style="{StaticResource PaperMetaStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="6" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                            <Button
                                Command="{Binding PreviousPageCommand}"
                                Style="{StaticResource NoteButtonStyle}"
                                ToolTipService.ToolTip="上一页"
                                AutomationProperties.Name="上一页">
                                <FontIcon Glyph="&#xE76B;" FontSize="12" />
                            </Button>
                            <Button
                                Command="{Binding NextPageCommand}"
                                Style="{StaticResource NoteButtonStyle}"
                                ToolTipService.ToolTip="下一页"
                                AutomationProperties.Name="下一页">
                                <FontIcon Glyph="&#xE76C;" FontSize="12" />
                            </Button>
                        </StackPanel>
                        <TextBlock Text="{Binding TodayStampText}" FontSize="12" HorizontalAlignment="Right" Foreground="{StaticResource NoteMutedBrush}" />
                        <TextBlock Text="{Binding PageDotsText}" FontSize="14" HorizontalAlignment="Right" Foreground="#D69A20" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2" Margin="23,0,20,2">
                    <ScrollViewer
                        HorizontalScrollBarVisibility="Disabled"
                        HorizontalScrollMode="Disabled"
                        Visibility="{Binding PlanInputPageVisibility}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="描述今日状态" Style="{StaticResource PaperLabelStyle}" />
                            <TextBox
                                MinHeight="118"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                Text="{Binding Study.TodayState, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="例如：考试快到了，有点焦虑；或者今天状态不错，想多复习一点…" />

                            <Grid ColumnSpacing="9">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <DatePicker Header="计划日期" Date="{Binding Study.TodayDateValue, Mode=TwoWay}" />
                                <Button
                                    Grid.Column="1"
                                    Command="{Binding Study.GenerateAdviceCommand}"
                                    IsEnabled="{Binding Study.IsNotBusy}"
                                    Style="{StaticResource NotePrimaryButtonStyle}"
                                    VerticalAlignment="Bottom">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <ProgressRing Width="13" Height="13" IsActive="{Binding Study.IsBusy}" Visibility="{Binding Study.BusyVisibility}" />
                                        <FontIcon Glyph="&#xE9D2;" FontSize="12" />
                                        <TextBlock Text="生成计划" Foreground="#FFF8DF" FontSize="13" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <Border Style="{StaticResource PaperPanelStyle}">
                                <StackPanel Spacing="5">
                                    <TextBlock Text="状态识别" Style="{StaticResource PaperLabelStyle}" />
                                    <TextBlock Text="{Binding Study.TodayLearningState}" FontSize="14" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Study.TodayEmotionDetails}" Style="{StaticResource PaperMetaStyle}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer
                        HorizontalScrollBarVisibility="Disabled"
                        HorizontalScrollMode="Disabled"
                        Visibility="{Binding AdvicePageVisibility}">
                        <StackPanel Spacing="10">
                            <Border Style="{StaticResource PaperPanelStyle}">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="今日建议" Style="{StaticResource PaperLabelStyle}" />
                                    <TextBlock Text="{Binding Study.TodayAdvice}" FontSize="14" LineHeight="21" IsTextSelectionEnabled="True" />
                                    <TextBlock Text="{Binding Study.AdviceSourceText}" Style="{StaticResource PaperMetaStyle}" />
                                </StackPanel>
                            </Border>

                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="推荐任务" Style="{StaticResource PaperLabelStyle}" />
                                <TextBlock Grid.Column="1" Text="{Binding Study.RecommendedTaskCountText}" Style="{StaticResource PaperMetaStyle}" />
                            </Grid>

                            <Border Style="{StaticResource PaperPanelStyle}" Visibility="{Binding Study.EmptyRecommendedTasksVisibility}">
                                <TextBlock Text="还没有推荐任务。录入课程、知识点和日程后，再生成今日计划。" Style="{StaticResource PaperMetaStyle}" />
                            </Border>

                            <ListView ItemsSource="{Binding Study.RecommendedTasks}" SelectionMode="None" Background="Transparent" MaxHeight="270">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource PaperRowStyle}">
                                            <Grid ColumnSpacing="9">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="21" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="15" Height="15" BorderBrush="#8B7140" BorderThickness="1.6" CornerRadius="3" VerticalAlignment="Top" Margin="1,3,0,0" />
                                                <StackPanel Grid.Column="1" Spacing="2">
                                                    <TextBlock Text="{Binding TopicName}" FontSize="14" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding CourseAndMinutesText}" Style="{StaticResource PaperMetaStyle}" />
                                                    <TextBlock Text="{Binding Reason}" Style="{StaticResource PaperMetaStyle}" MaxLines="2" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="{Binding PriorityText}" Foreground="{StaticResource NoteAccentBrush}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Top" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Visibility="{Binding SchedulePageVisibility}" RowSpacing="9">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="DDL 清单" Style="{StaticResource PaperLabelStyle}" />
                            <Border Grid.Column="1" Padding="7,2" CornerRadius="999" Background="#4CF4C75C" BorderBrush="#9CB98125" BorderThickness="1">
                                <TextBlock Text="仅查看" FontSize="11" Foreground="{StaticResource NoteMutedBrush}" />
                            </Border>
                        </Grid>

                        <Border Grid.Row="1" BorderBrush="#52CFAE55" BorderThickness="0,1,0,1" Padding="0,2">
                            <ListView ItemsSource="{Binding Study.UpcomingEvents}" SelectionMode="None" Background="Transparent">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource PaperRowStyle}">
                                            <Grid ColumnSpacing="9">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="21" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="15" Height="15" BorderBrush="#7D6636" BorderThickness="1.6" CornerRadius="3" VerticalAlignment="Top" Margin="1,3,0,0" />
                                                <StackPanel Grid.Column="1" Spacing="2">
                                                    <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding StartTimeDisplay}" Style="{StaticResource PaperMetaStyle}" />
                                                    <TextBlock Text="{Binding RemainingTopicsText}" Style="{StaticResource PaperMetaStyle}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" HorizontalAlignment="Right" Spacing="2">
                                                    <TextBlock Text="{Binding DaysLeftText}" Foreground="{StaticResource NoteAccentBrush}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right" />
                                                    <TextBlock Text="{Binding EventType}" Style="{StaticResource PaperMetaStyle}" HorizontalAlignment="Right" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>

                        <Border
                            Grid.Row="2"
                            Padding="12"
                            CornerRadius="11"
                            BorderBrush="#CFA03F27"
                            BorderThickness="1"
                            Background="#42FFE7B5">
                            <Grid ColumnSpacing="9">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE7BA;" FontSize="23" Foreground="{StaticResource NoteWarningBrush}" VerticalAlignment="Top" />
                                <StackPanel Grid.Column="1" Spacing="3">
                                    <TextBlock Text="紧急提醒" Foreground="{StaticResource NoteWarningBrush}" FontSize="15" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Study.NextUpcomingEventText}" FontSize="14" LineHeight="21" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Visibility="{Binding TopicsPageVisibility}" RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="课程知识点" Style="{StaticResource PaperLabelStyle}" />
                            <TextBlock Grid.Column="1" Text="{Binding Study.OverallProgressText}" Style="{StaticResource PaperMetaStyle}" />
                        </Grid>

                        <ListView Grid.Row="1" ItemsSource="{Binding Study.Topics}" SelectionMode="None" Background="Transparent">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource PaperRowStyle}">
                                        <Grid ColumnSpacing="9">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="21" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="15" Height="15" BorderBrush="#7D6636" BorderThickness="1.6" CornerRadius="3" VerticalAlignment="Top" Margin="1,3,0,0" />
                                            <StackPanel Grid.Column="1" Spacing="2">
                                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding CourseDisplay}" Style="{StaticResource PaperMetaStyle}" />
                                                <StackPanel Orientation="Horizontal" Spacing="7">
                                                    <TextBlock Text="{Binding EstimatedText}" Style="{StaticResource PaperMetaStyle}" />
                                                    <TextBlock Text="{Binding ImportanceText}" Style="{StaticResource PaperMetaStyle}" />
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" HorizontalAlignment="Right" Spacing="2">
                                                <TextBlock Text="{Binding MasteryLevel}" Foreground="{StaticResource NoteAccentBrush}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right" />
                                                <TextBlock Text="{Binding StatusDisplay}" Style="{StaticResource PaperMetaStyle}" HorizontalAlignment="Right" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>

                <Grid Grid.Row="3" Margin="23,5,23,15" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Text="{Binding Study.StatusMessage}"
                        Style="{StaticResource PaperMetaStyle}"
                        MaxLines="1"
                        TextTrimming="CharacterEllipsis"
                        VerticalAlignment="Center" />
                    <TextBlock
                        Grid.Column="1"
                        Text="{Binding PageNumberText}"
                        Foreground="{StaticResource NoteAccentBrush}"
                        FontSize="11"
                        FontWeight="SemiBold"
                        VerticalAlignment="Center" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
