<Window
    x:Class="StudyMind.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="Root" Background="{ThemeResource StudyMindPageBackgroundBrush}" SizeChanged="Root_SizeChanged">
        <Grid.Resources>
            <Style TargetType="Button">
                <Setter Property="MinWidth" Value="44" />
                <Setter Property="MinHeight" Value="44" />
            </Style>
            <Style TargetType="FontIcon">
                <Setter Property="AutomationProperties.AccessibilityView" Value="Raw" />
            </Style>
            <Style TargetType="ProgressRing">
                <Setter Property="AutomationProperties.AccessibilityView" Value="Raw" />
            </Style>

            <Style x:Key="PanelBorderStyle" TargetType="Border">
                <Setter Property="Padding" Value="18" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="{ThemeResource StudyMindPanelStrokeBrush}" />
                <Setter Property="Background" Value="{ThemeResource StudyMindPanelBrush}" />
            </Style>
            <Style x:Key="HeroPanelBorderStyle" TargetType="Border">
                <Setter Property="Padding" Value="22" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="{ThemeResource StudyMindAccentSoftBrush}" />
                <Setter Property="Background" Value="{ThemeResource StudyMindHeroBrush}" />
            </Style>
            <Style x:Key="SoftTileBorderStyle" TargetType="Border">
                <Setter Property="Padding" Value="14" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="{ThemeResource StudyMindPanelStrokeBrush}" />
                <Setter Property="Background" Value="{ThemeResource StudyMindSoftSurfaceBrush}" />
            </Style>
            <Style x:Key="FocusTileBorderStyle" BasedOn="{StaticResource SoftTileBorderStyle}" TargetType="Border">
                <Setter Property="BorderBrush" Value="{ThemeResource StudyMindInfoBrush}" />
                <Setter Property="Background" Value="{ThemeResource StudyMindInfoSoftBrush}" />
            </Style>
            <Style x:Key="RiskTileBorderStyle" BasedOn="{StaticResource SoftTileBorderStyle}" TargetType="Border">
                <Setter Property="BorderBrush" Value="{ThemeResource StudyMindWarningBrush}" />
                <Setter Property="Background" Value="{ThemeResource StudyMindWarningSoftBrush}" />
            </Style>
            <Style x:Key="SuccessTileBorderStyle" BasedOn="{StaticResource SoftTileBorderStyle}" TargetType="Border">
                <Setter Property="BorderBrush" Value="{ThemeResource StudyMindSuccessBrush}" />
                <Setter Property="Background" Value="{ThemeResource StudyMindSuccessSoftBrush}" />
            </Style>
            <Style x:Key="DataTileBorderStyle" BasedOn="{StaticResource SoftTileBorderStyle}" TargetType="Border">
                <Setter Property="BorderBrush" Value="{ThemeResource StudyMindInfoBrush}" />
                <Setter Property="Background" Value="{ThemeResource StudyMindInfoSoftBrush}" />
            </Style>
            <Style x:Key="PillBorderStyle" TargetType="Border">
                <Setter Property="Padding" Value="10,5" />
                <Setter Property="CornerRadius" Value="999" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="{ThemeResource StudyMindAccentSoftBrush}" />
                <Setter Property="Background" Value="{ThemeResource StudyMindSoftSurfaceBrush}" />
            </Style>
            <Style x:Key="InfoPillBorderStyle" BasedOn="{StaticResource PillBorderStyle}" TargetType="Border">
                <Setter Property="BorderBrush" Value="{ThemeResource StudyMindInfoBrush}" />
                <Setter Property="Background" Value="{ThemeResource StudyMindInfoSoftBrush}" />
            </Style>
            <Style x:Key="WarningPillBorderStyle" BasedOn="{StaticResource PillBorderStyle}" TargetType="Border">
                <Setter Property="BorderBrush" Value="{ThemeResource StudyMindWarningBrush}" />
                <Setter Property="Background" Value="{ThemeResource StudyMindWarningSoftBrush}" />
            </Style>
            <Style x:Key="SuccessPillBorderStyle" BasedOn="{StaticResource PillBorderStyle}" TargetType="Border">
                <Setter Property="BorderBrush" Value="{ThemeResource StudyMindSuccessBrush}" />
                <Setter Property="Background" Value="{ThemeResource StudyMindSuccessSoftBrush}" />
            </Style>
            <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="17" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>
            <Style x:Key="HeroTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="24" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
            <Style x:Key="MetaTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource StudyMindTextMutedBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
            <Style x:Key="ErrorTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource StudyMindDangerBrush}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="AutomationProperties.LiveSetting" Value="Polite" />
            </Style>
            <Style x:Key="MetricValueTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
            <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
                <Setter Property="MinHeight" Value="44" />
                <Setter Property="Padding" Value="16,9" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Background" Value="{ThemeResource StudyMindAccentBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource StudyMindAccentBrush}" />
                <Setter Property="Foreground" Value="White" />
            </Style>
            <Style x:Key="CompactIconButtonStyle" TargetType="Button">
                <Setter Property="MinWidth" Value="44" />
                <Setter Property="MinHeight" Value="44" />
                <Setter Property="Padding" Value="8,6" />
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <NavigationView
            x:Name="ShellNav"
            Grid.Row="0"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            CompactModeThresholdWidth="720"
            CompactPaneLength="56"
            ExpandedModeThresholdWidth="980"
            OpenPaneLength="220"
            PaneDisplayMode="Auto"
            SelectionChanged="ShellNav_SelectionChanged">
            <NavigationView.Header>
                <Grid MinHeight="56" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Text="{Binding CurrentPageTitle}"
                        FontSize="30"
                        FontWeight="SemiBold"
                        VerticalAlignment="Center"
                        TextWrapping="NoWrap" />

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="0,0,24,0" VerticalAlignment="Center">
                        <Button Click="ShowCyberNote_Click" VerticalAlignment="Center" ToolTipService.ToolTip="打开桌面便签" AutomationProperties.Name="打开桌面便签">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8A7;" FontSize="14" />
                                <TextBlock Text="便签" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding RefreshCommand}" IsEnabled="{Binding IsNotBusy}" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE72C;" FontSize="14" />
                                <TextBlock Text="刷新" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </NavigationView.Header>

            <NavigationView.PaneFooter>
                <Border Padding="16,12" BorderThickness="0,1,0,0" BorderBrush="{ThemeResource StudyMindPanelStrokeBrush}">
                    <StackPanel Spacing="6">
                        <ProgressBar IsIndeterminate="{Binding IsBusy}" Visibility="{Binding BusyVisibility}" Height="2" />
                        <TextBlock
                            Text="{Binding StatusMessage}"
                            Style="{StaticResource MetaTextStyle}"
                            MaxLines="2"
                            TextTrimming="CharacterEllipsis"
                            AutomationProperties.LiveSetting="Polite" />
                    </StackPanel>
                </Border>
            </NavigationView.PaneFooter>

            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="TodayNav" Content="今日计划" Tag="today">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE787;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="CoursesNav" Content="课程知识点" Tag="courses">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE82D;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="ScheduleNav" Content="日程" Tag="schedule">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE787;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="RecordsNav" Content="学习记录" Tag="records">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE70B;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="ReviewNav" Content="复盘" Tag="review">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D2;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="SettingsNav" Content="设置" Tag="settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Grid Padding="24,12,24,24">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" HorizontalScrollMode="Disabled" Visibility="{Binding TodayPageVisibility}">
                    <Grid x:Name="TodayLayout" ColumnSpacing="18" RowSpacing="18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="TodayPrimaryColumn" Width="0.86*" />
                            <ColumnDefinition x:Name="TodaySecondaryColumn" Width="1.34*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="18">
                            <Border Style="{StaticResource HeroPanelBorderStyle}">
                                <StackPanel Spacing="14">
                                    <TextBlock Text="从状态到学习动作" Style="{StaticResource HeroTitleStyle}" />
                                    <TextBlock Text="写下此刻的状态，StudyMind 会把情绪、DDL 和学习记录整理成一份可执行计划。" Style="{StaticResource MetaTextStyle}" />
                                    <Border Style="{StaticResource PillBorderStyle}" HorizontalAlignment="Left" Visibility="{Binding FirstRunHintVisibility}">
                                        <TextBlock Text="补充课程和 DDL 后，推荐会更准确" Foreground="{ThemeResource StudyMindAccentBrush}" FontSize="12" />
                                    </Border>
                                    <DatePicker Header="日期" Date="{Binding TodayDateValue, Mode=TwoWay}" />
                                    <TextBox
                                        Header="今日状态"
                                        Height="128"
                                        AcceptsReturn="True"
                                        TextWrapping="Wrap"
                                        Text="{Binding TodayState, Mode=TwoWay}"
                                        PlaceholderText="例如：考试快到了，有点焦虑；或者今天状态不错，想多复习一点…" />
                                    <Button Command="{Binding GenerateAdviceCommand}" HorizontalAlignment="Left" IsEnabled="{Binding IsNotBusy}" Style="{StaticResource PrimaryActionButtonStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE9D2;" FontSize="14" />
                                            <ProgressRing Width="16" Height="16" IsActive="{Binding IsBusy}" Visibility="{Binding BusyVisibility}" />
                                            <TextBlock Text="生成今日计划" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource PanelBorderStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="状态与节奏" Style="{StaticResource SectionTitleStyle}" />
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource SoftTileBorderStyle}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="情绪 / 压力" Style="{StaticResource MetaTextStyle}" FontSize="12" />
                                                <TextBlock Text="{Binding TodayEmotion}" Style="{StaticResource MetricValueTextStyle}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Style="{StaticResource SoftTileBorderStyle}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="学习状态 / 强度" Style="{StaticResource MetaTextStyle}" FontSize="12" />
                                                <TextBlock Text="{Binding TodayLearningState}" Style="{StaticResource MetricValueTextStyle}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                    <Border Style="{StaticResource SoftTileBorderStyle}">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="分析依据" Style="{StaticResource MetaTextStyle}" FontSize="12" />
                                            <TextBlock Text="{Binding TodayEmotionDetails}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <InfoBar
                                        IsOpen="True"
                                        Severity="Warning"
                                        Title="建议来源"
                                        Message="{Binding AdviceSourceText}"
                                        Visibility="{Binding FallbackNoticeVisibility}" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource PanelBorderStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="今日概览" Style="{StaticResource SectionTitleStyle}" />
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource SoftTileBorderStyle}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="学习总时长" Style="{StaticResource MetaTextStyle}" FontSize="12" />
                                                <TextBlock Text="{Binding StatsTotalMinutes}" Style="{StaticResource MetricValueTextStyle}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Style="{StaticResource SoftTileBorderStyle}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="知识点进度" Style="{StaticResource MetaTextStyle}" FontSize="12" />
                                                <TextBlock Text="{Binding OverallProgressText}" Style="{StaticResource MetricValueTextStyle}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                    <Border Style="{StaticResource FocusTileBorderStyle}">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="今日重点" Foreground="{ThemeResource StudyMindInfoBrush}" FontSize="12" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding TodayFocusText}" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding NextUpcomingEventText}" Style="{StaticResource MetaTextStyle}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="TodayOutputPanel" Grid.Column="1" Spacing="18">
                            <Border Style="{StaticResource PanelBorderStyle}">
                                <StackPanel Spacing="14">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="今日建议" Style="{StaticResource SectionTitleStyle}" />
                                        <Border Grid.Column="1" Style="{StaticResource InfoPillBorderStyle}">
                                            <TextBlock Text="{Binding AdviceSourceText}" Foreground="{ThemeResource StudyMindInfoBrush}" FontSize="12" MaxWidth="220" TextTrimming="CharacterEllipsis" />
                                        </Border>
                                    </Grid>
                                    <Border Style="{StaticResource FocusTileBorderStyle}">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="下一步" Foreground="{ThemeResource StudyMindInfoBrush}" FontSize="12" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding TodayFocusText}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Text="{Binding TodayAdvice}" TextWrapping="Wrap" IsTextSelectionEnabled="True" FontSize="16" LineHeight="24" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource PanelBorderStyle}">
                                <StackPanel Spacing="12">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="推荐任务" Style="{StaticResource SectionTitleStyle}" />
                                        <TextBlock Grid.Column="1" Text="{Binding RecommendedTaskCountText}" Style="{StaticResource MetaTextStyle}" />
                                    </Grid>
                                    <Border Style="{StaticResource SoftTileBorderStyle}" Visibility="{Binding EmptyRecommendedTasksVisibility}">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="还没有推荐任务" FontWeight="SemiBold" />
                                            <TextBlock Text="录入课程、知识点和日程后，再生成今日计划。" Style="{StaticResource MetaTextStyle}" />
                                        </StackPanel>
                                    </Border>
                                    <ListView ItemsSource="{Binding RecommendedTasks}" MaxHeight="520">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource SoftTileBorderStyle}" Margin="0,0,0,8">
                                                    <Grid RowSpacing="8" ColumnSpacing="12">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding TopicName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding CourseAndMinutesText}" Style="{StaticResource MetaTextStyle}" />
                                                        </StackPanel>
                                                        <Border Grid.Column="1" Style="{StaticResource WarningPillBorderStyle}">
                                                            <TextBlock Text="{Binding PriorityText}" Foreground="{ThemeResource StudyMindWarningBrush}" FontSize="12" FontWeight="SemiBold" />
                                                        </Border>
                                                        <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Reason}" TextWrapping="Wrap" Foreground="{ThemeResource StudyMindTextMutedBrush}" />
                                                        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8">
                                                            <Button
                                                                Command="{Binding DataContext.UseTaskForRecordCommand, ElementName=Root}"
                                                                CommandParameter="{Binding}"
                                                                IsEnabled="{Binding DataContext.IsNotBusy, ElementName=Root}">
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <FontIcon Glyph="&#xE70B;" FontSize="14" />
                                                                    <TextBlock Text="记录学习" />
                                                                </StackPanel>
                                                            </Button>
                                                            <Button
                                                                Command="{Binding DataContext.CompleteRecommendedTaskCommand, ElementName=Root}"
                                                                CommandParameter="{Binding}"
                                                                IsEnabled="{Binding DataContext.IsNotBusy, ElementName=Root}"
                                                                Style="{StaticResource PrimaryActionButtonStyle}">
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <FontIcon Glyph="&#xE930;" FontSize="14" />
                                                                    <ProgressRing Width="16" Height="16" IsActive="{Binding DataContext.IsBusy, ElementName=Root}" Visibility="{Binding DataContext.BusyVisibility, ElementName=Root}" />
                                                                    <TextBlock Text="完成并记录" />
                                                                </StackPanel>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <ScrollViewer HorizontalScrollBarVisibility="Disabled" HorizontalScrollMode="Disabled" Visibility="{Binding CoursesPageVisibility}">
                    <Grid x:Name="CoursesLayout" RowSpacing="18">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup>
                                <VisualState x:Name="CoursesNarrow" />
                                <VisualState x:Name="CoursesWide">
                                    <VisualState.StateTriggers>
                                        <AdaptiveTrigger MinWindowWidth="500" />
                                    </VisualState.StateTriggers>
                                    <VisualState.Setters>
                                        <Setter Target="CoursesLayout.ColumnSpacing" Value="18" />
                                        <Setter Target="CoursesPrimaryColumn.Width" Value="0.8*" />
                                        <Setter Target="CoursesSecondaryColumn.Width" Value="1.25*" />
                                        <Setter Target="CoursesListPanel.(Grid.Row)" Value="0" />
                                        <Setter Target="CoursesListPanel.(Grid.Column)" Value="1" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="CoursesPrimaryColumn" Width="*" />
                            <ColumnDefinition x:Name="CoursesSecondaryColumn" Width="0" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="18">
                            <Border Style="{StaticResource PanelBorderStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="课程维护" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="{Binding CourseEditorModeText}" Style="{StaticResource MetaTextStyle}" />
                                    <InfoBar IsOpen="True" Severity="Warning" Title="需要处理" Message="{Binding FormMessage}" Visibility="{Binding FormMessageVisibility}" AutomationProperties.LiveSetting="Polite" />
                                    <TextBox x:Name="CourseNameBox" Header="课程名称 *" Text="{Binding NewCourseName, Mode=TwoWay}" />
                                    <TextBlock Text="{Binding CourseNameError}" Style="{StaticResource ErrorTextStyle}" Visibility="{Binding CourseNameErrorVisibility}" />
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                        <Button Command="{Binding SaveCourseCommand}" IsEnabled="{Binding IsNotBusy}" Style="{StaticResource PrimaryActionButtonStyle}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE74E;" FontSize="14" />
                                                <ProgressRing Width="16" Height="16" IsActive="{Binding IsBusy}" Visibility="{Binding BusyVisibility}" />
                                                <TextBlock Text="保存课程" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="1" Command="{Binding ResetCourseFormCommand}" IsEnabled="{Binding IsNotBusy}" Style="{StaticResource CompactIconButtonStyle}" ToolTipService.ToolTip="新建课程" AutomationProperties.Name="新建课程">
                                            <FontIcon Glyph="&#xE894;" FontSize="14" />
                                        </Button>
                                        <Button Grid.Column="2" Click="DeleteCourse_Click" IsEnabled="{Binding IsNotBusy}" Foreground="{ThemeResource StudyMindDangerBrush}" Style="{StaticResource CompactIconButtonStyle}" ToolTipService.ToolTip="删除课程及关联数据" AutomationProperties.Name="删除课程及关联数据">
                                            <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                        </Button>
                                    </Grid>
                                    <InfoBar
                                        IsOpen="True"
                                        Severity="Informational"
                                        Title="还没有课程"
                                        Message="先添加课程，再为课程建立知识点。"
                                        Visibility="{Binding EmptyCoursesVisibility}" />
                                    <ListView ItemsSource="{Binding Courses}" SelectedItem="{Binding SelectedCourse, Mode=TwoWay}" MaxHeight="220">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}" Padding="4" />
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource PanelBorderStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="知识点表单" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="{Binding TopicEditorModeText}" Style="{StaticResource MetaTextStyle}" />
                                    <InfoBar IsOpen="True" Severity="Warning" Title="需要处理" Message="{Binding FormMessage}" Visibility="{Binding FormMessageVisibility}" AutomationProperties.LiveSetting="Polite" />
                                    <ComboBox x:Name="TopicCourseBox" Header="所属课程 *" ItemsSource="{Binding Courses}" SelectedItem="{Binding SelectedTopicCourse, Mode=TwoWay}" DisplayMemberPath="Name" />
                                    <TextBlock Text="{Binding TopicCourseError}" Style="{StaticResource ErrorTextStyle}" Visibility="{Binding TopicCourseErrorVisibility}" />
                                    <TextBox x:Name="TopicNameBox" Header="知识点名称 *" Text="{Binding NewTopicName, Mode=TwoWay}" />
                                    <TextBlock Text="{Binding TopicNameError}" Style="{StaticResource ErrorTextStyle}" Visibility="{Binding TopicNameErrorVisibility}" />
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Header="掌握程度" SelectedValue="{Binding NewTopicMastery, Mode=TwoWay}" SelectedValuePath="Content">
                                            <ComboBoxItem Content="未掌握" />
                                            <ComboBoxItem Content="学习中" />
                                            <ComboBoxItem Content="已掌握" />
                                        </ComboBox>
                                        <NumberBox Grid.Column="1" Header="重要性" Minimum="1" Maximum="5" SmallChange="1" LargeChange="1" SpinButtonPlacementMode="Inline" Value="{Binding NewTopicImportance, Mode=TwoWay}" />
                                        <NumberBox Grid.Column="2" Header="预计分钟" Minimum="5" Maximum="240" SmallChange="5" LargeChange="15" SpinButtonPlacementMode="Inline" Value="{Binding NewTopicMinutes, Mode=TwoWay}" />
                                    </Grid>
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Header="关联考试/DDL" ItemsSource="{Binding Events}" SelectedItem="{Binding SelectedTopicEvent, Mode=TwoWay}" DisplayMemberPath="Title" />
                                        <ComboBox Grid.Column="1" Header="任务状态" SelectedValue="{Binding NewTopicStatus, Mode=TwoWay}" SelectedValuePath="Tag">
                                            <ComboBoxItem Content="待学习" Tag="pending" />
                                            <ComboBoxItem Content="已完成" Tag="completed" />
                                        </ComboBox>
                                    </Grid>
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
