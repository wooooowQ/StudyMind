                                    <TextBlock Text="情绪趋势" Style="{StaticResource SectionTitleStyle}" />
                                    <Grid Height="230">
                                        <lvc:CartesianChart
                                            Series="{Binding EmotionScoreSeries}"
                                            XAxes="{Binding EmotionXAxes}"
                                            YAxes="{Binding EmotionYAxes}" />
                                        <Border
                                            Padding="16"
                                            Background="{ThemeResource StudyMindSoftSurfaceBrush}"
                                            Visibility="{Binding EmptyEmotionChartVisibility}">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Text="暂无情绪记录。在今日计划里写下状态后，这里会显示变化趋势。"
                                                TextWrapping="Wrap" />
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <Border x:Name="CourseProgressPanel" Grid.Row="1" Style="{StaticResource PanelBorderStyle}">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="课程完成率" Style="{StaticResource SectionTitleStyle}" />
                                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding OverallCompletionRate}" Height="10" />
                                    <TextBlock Text="{Binding ReviewInsightText}" Style="{StaticResource MetaTextStyle}" />
                                    <ListView ItemsSource="{Binding TopicProgress}" MaxHeight="220">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Padding="6" Spacing="4">
                                                    <Grid ColumnSpacing="8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding CourseName}" FontWeight="SemiBold" />
                                                        <TextBlock Grid.Column="1" Text="{Binding CompletionRateText}" Opacity="0.72" />
                                                    </Grid>
                                                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding CompletionRate}" Height="6" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Style="{StaticResource PanelBorderStyle}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="最近考试 / DDL" Style="{StaticResource SectionTitleStyle}" />
                                <InfoBar
                                    IsOpen="True"
                                    Severity="Informational"
                                    Title="暂无临近日程"
                                    Message="添加考试或 DDL 后，这里会展示倒计时和未完成知识点数量。"
                                    Visibility="{Binding EmptyUpcomingEventsVisibility}" />
                                <ListView ItemsSource="{Binding UpcomingEvents}" MaxHeight="220">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource SoftTileBorderStyle}" Margin="0,0,0,8">
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="4" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Background="{ThemeResource StudyMindWarningBrush}" CornerRadius="2" />
                                                    <StackPanel Grid.Column="1" Spacing="4">
                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                                            <TextBlock Text="{Binding EventType}" Foreground="{ThemeResource StudyMindTextMutedBrush}" />
                                                            <TextBlock Text="{Binding StartTimeDisplay}" Foreground="{ThemeResource StudyMindTextMutedBrush}" />
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding RemainingTopicsText}" Style="{StaticResource MetaTextStyle}" />
                                                    </StackPanel>
                                                    <Border Grid.Column="2" Style="{StaticResource WarningPillBorderStyle}" VerticalAlignment="Top">
                                                        <TextBlock Text="{Binding DaysLeftText}" Foreground="{ThemeResource StudyMindWarningBrush}" FontSize="12" FontWeight="SemiBold" />
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer HorizontalScrollBarVisibility="Disabled" HorizontalScrollMode="Disabled" Visibility="{Binding SettingsPageVisibility}">
                    <Grid x:Name="SettingsLayout" RowSpacing="18">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup>
                                <VisualState x:Name="SettingsNarrow" />
                                <VisualState x:Name="SettingsWide">
                                    <VisualState.StateTriggers>
                                        <AdaptiveTrigger MinWindowWidth="500" />
                                    </VisualState.StateTriggers>
                                    <VisualState.Setters>
                                        <Setter Target="SettingsLayout.ColumnSpacing" Value="18" />
                                        <Setter Target="SettingsPrimaryColumn.Width" Value="1.05*" />
                                        <Setter Target="SettingsSecondaryColumn.Width" Value="0.95*" />
                                        <Setter Target="SettingsSidePanel.(Grid.Row)" Value="0" />
                                        <Setter Target="SettingsSidePanel.(Grid.Column)" Value="1" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="SettingsPrimaryColumn" Width="*" />
                            <ColumnDefinition x:Name="SettingsSecondaryColumn" Width="0" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource PanelBorderStyle}">
                            <StackPanel Spacing="14">
                                <TextBlock Text="AI 建议设置" Style="{StaticResource SectionTitleStyle}" />
                                <InfoBar
                                    IsOpen="True"
                                    Severity="Informational"
                                    Title="隐私提示"
                                    Message="启用 AI 模式时，今日状态文本和结构化学习摘要会发送到你配置的兼容接口。" />
                                <StackPanel Spacing="10">
                                    <ComboBox Header="建议模式" SelectedValue="{Binding AdviceMode, Mode=TwoWay}" SelectedValuePath="Tag">
                                        <ComboBoxItem Content="本地规则" Tag="rules" />
                                        <ComboBoxItem Content="优先 AI" Tag="hybrid" />
                                        <ComboBoxItem Content="仅 AI" Tag="ai" />
                                    </ComboBox>
                                    <TextBox Header="Base URL" Text="{Binding AiBaseUrl, Mode=TwoWay}" />
                                    <TextBox Header="模型" Text="{Binding AiModel, Mode=TwoWay}" />
                                </StackPanel>
                                <PasswordBox x:Name="AiApiKeyBox" Header="API Key" PlaceholderText="留空表示不修改已保存的 Key…" PasswordChanged="AiApiKeyBox_PasswordChanged" />
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding AiKeyStatus}" Style="{StaticResource MetaTextStyle}" />
                                        <TextBlock Text="{Binding AdviceModeDescription}" Style="{StaticResource MetaTextStyle}" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Click="SaveSettings_Click" IsEnabled="{Binding IsNotBusy}" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE74E;" FontSize="14" />
                                            <ProgressRing Width="16" Height="16" IsActive="{Binding IsBusy}" Visibility="{Binding BusyVisibility}" />
                                            <TextBlock Text="保存设置" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <StackPanel x:Name="SettingsSidePanel" Grid.Row="1" Spacing="18">
                            <Border Style="{StaticResource PanelBorderStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="本地数据" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="{Binding DatabasePath}" Style="{StaticResource MetaTextStyle}" IsTextSelectionEnabled="True" />
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Command="{Binding ExportCommand}" IsEnabled="{Binding IsNotBusy}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE74E;" FontSize="14" />
                                                <ProgressRing Width="16" Height="16" IsActive="{Binding IsBusy}" Visibility="{Binding BusyVisibility}" />
                                                <TextBlock Text="导出 JSON" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="1" Command="{Binding BackupCommand}" IsEnabled="{Binding IsNotBusy}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE777;" FontSize="14" />
                                                <ProgressRing Width="16" Height="16" IsActive="{Binding IsBusy}" Visibility="{Binding BusyVisibility}" />
                                                <TextBlock Text="备份数据库" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource PanelBorderStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="应用状态" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MetaTextStyle}" />
                                    <TextBlock Text="所有学习记录、情绪日志和建议日志默认保存在本机 SQLite 数据库中。" Style="{StaticResource MetaTextStyle}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </NavigationView>
    </Grid>
</Window>
